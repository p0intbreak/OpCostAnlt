{% extends "base.html.j2" %}

{% block body %}
  <main class="page-shell">
    <section class="hero">
      <div class="hero-card">
        <div class="hero-topline">IT Spend Storyboard</div>
        <h1>{{ title }}</h1>
        <p class="subtitle">
          Интерактивный дашборд расходов IT-департамента с упором на управленческий сторилайн,
          кликабельные срезы и детальную расшифровку без backend.
        </p>
        <div class="hero-meta">
          <span class="meta-pill">Валюта: {{ metadata.currency }}</span>
          <span class="meta-pill">Годы: {{ metadata.available_years | join(", ") }}</span>
          <span class="meta-pill">Строк детализации: {{ metadata.detail_rows_count }}</span>
          <span class="meta-pill">Сформирован: {{ metadata.generated_at }}</span>
        </div>
      </div>
    </section>

    <section class="group-panel">
      <div class="group-header">
        <div>
          <div class="group-kicker">1. Executive Story</div>
          <h2 class="group-title">С чего начинается чтение дашборда</h2>
        </div>
      </div>
      <div class="story-grid">
        <article class="story-card story-card-primary" id="story-main-card">
          <div class="story-eyebrow">Главный вывод</div>
          <h3 id="story-main-title" class="story-title"></h3>
          <div id="story-main-metric" class="story-metric"></div>
          <p id="story-main-text" class="story-text"></p>
        </article>
        <article class="story-card">
          <div class="story-eyebrow">Что растет</div>
          <h3 id="story-growth-title" class="story-title"></h3>
          <div id="story-growth-metric" class="story-metric"></div>
          <p id="story-growth-text" class="story-text"></p>
        </article>
        <article class="story-card">
          <div class="story-eyebrow">Что требует внимания</div>
          <h3 id="story-risk-title" class="story-title"></h3>
          <div id="story-risk-metric" class="story-metric"></div>
          <p id="story-risk-text" class="story-text"></p>
        </article>
      </div>
      <div class="insights-inline">
        <div class="section-header compact">
          <div>
            <h3 class="section-title">Панель инсайтов</h3>
            <div class="section-caption">Top-5 управленческих сигналов для перехода в нужный срез</div>
          </div>
        </div>
        <div id="insights-grid" class="insights-grid"></div>
      </div>
    </section>

    <section class="group-panel">
      <div class="group-header">
        <div>
          <div class="group-kicker">2. Executive Snapshot</div>
          <h2 class="group-title">Масштаб, годовое сравнение и зависшие суммы</h2>
        </div>
      </div>
      <section id="kpi-grid" class="kpi-grid"></section>
      <div class="content-grid">
        <article class="section-card span-7">
          <div class="section-header">
            <div>
              <h3 class="section-title">Годовое сравнение 2025 vs 2026</h3>
              <div class="section-caption">Как изменился общий объем расходов по годам</div>
            </div>
          </div>
          <div id="year-comparison-chart" class="chart"></div>
        </article>

        <article class="section-card span-5">
          <div class="section-header">
            <div>
              <h3 class="section-title">Статусы и зависшие суммы</h3>
              <div class="section-caption">Где деньги оплачены, а где остаются в цикле согласования</div>
            </div>
          </div>
          <div id="status-breakdown-chart" class="chart"></div>
        </article>
      </div>
    </section>

    <section class="group-panel">
      <div class="group-header">
        <div>
          <div class="group-kicker">3. Spend Structure</div>
          <h2 class="group-title">Куда уходят деньги и кто концентрирует бюджет</h2>
        </div>
      </div>
      <div class="content-grid">
        <article class="section-card span-7">
          <div class="section-header">
            <div>
              <h3 class="section-title">Структура расходов L1/L2/L3</h3>
              <div class="section-caption">Treemap показывает, где сосредоточена основная масса бюджета</div>
            </div>
          </div>
          <div id="category-breadcrumb" class="breadcrumb-bar"></div>
          <div id="categories-tree-chart" class="chart chart-tall"></div>
        </article>

        <article class="section-card span-5">
          <div class="section-header">
            <div>
              <h3 class="section-title">Крупнейшие категории</h3>
              <div class="section-caption">Быстрый рейтинг категорий L1 по сумме расходов</div>
            </div>
          </div>
          <div id="category-ranking-chart" class="chart"></div>
        </article>

        <article class="section-card span-12">
          <div class="section-header">
            <div>
              <h3 class="section-title">Поставщики: год → месяцы → состав месяца</h3>
              <div class="section-caption">Топ-10 поставщиков по сумме за выбранный год, помесячная динамика выбранного поставщика и детализация выбранного месяца по составляющим</div>
            </div>
          </div>
          <div id="vendor-drilldown-state" class="section-caption vendor-drilldown-state"></div>
          <div class="vendor-drilldown-grid">
            <div class="vendor-drilldown-panel">
              <div class="vendor-drilldown-title">Топ-10 поставщиков за год</div>
              <div id="vendors-top-chart" class="chart chart-compact"></div>
            </div>
            <div class="vendor-drilldown-panel">
              <div class="vendor-drilldown-title">Месяцы выбранного поставщика</div>
              <div id="vendor-monthly-chart" class="chart chart-compact"></div>
            </div>
            <div class="vendor-drilldown-panel">
              <div class="vendor-drilldown-title">Состав выбранного месяца</div>
              <div id="vendor-components-chart" class="chart chart-compact"></div>
            </div>
          </div>
        </article>

        <article class="section-card span-6">
          <div class="section-header">
            <div>
              <h3 class="section-title">Организации / подразделения</h3>
              <div class="section-caption">Какие оргсущности и команды тянут бюджет на себя</div>
            </div>
          </div>
          <div id="organizations-chart" class="chart"></div>
          <div id="departments-chart" class="chart chart-compact"></div>
        </article>
      </div>
    </section>

    <section class="group-panel">
      <div class="group-header">
        <div>
          <div class="group-kicker">4. Change Dynamics</div>
          <h2 class="group-title">Что меняется во времени и какие статьи растут</h2>
        </div>
      </div>
      <div class="content-grid">
        <article class="section-card span-8">
          <div class="section-header">
            <div>
              <h3 class="section-title">Динамика по месяцам</h3>
              <div class="section-caption">Тренд позволяет увидеть всплески и сезонность расходов</div>
            </div>
          </div>
          <div id="monthly-trends-chart" class="chart chart-tall"></div>
        </article>

        <article class="section-card span-4">
          <div class="section-header">
            <div>
              <h3 class="section-title">Рост категорий 2026 vs 2025</h3>
              <div class="section-caption">Какие категории L1 ускоряются быстрее остальных</div>
            </div>
          </div>
          <div id="category-yoy-chart" class="chart chart-tall"></div>
        </article>
      </div>
    </section>

    <section class="group-panel">
      <div class="group-header">
        <div>
          <div class="group-kicker">5. Drill-down</div>
          <h2 class="group-title">Переход к деталям</h2>
        </div>
      </div>
      <article class="table-card">
        <div class="section-header">
          <div>
            <h3 class="section-title">Детальная таблица</h3>
            <div class="section-caption">Client-side filtering, sorting и export без backend</div>
          </div>
        </div>

        <section class="filter-card inline-filter-card">
          <div class="section-header compact">
            <div>
              <h3 class="section-title">Фильтры</h3>
              <div class="section-caption">Связаны с графиками и карточками выше</div>
            </div>
          </div>
          <div class="filter-grid">
            <div>
              <label for="detail-year-filter">Год</label>
              <select id="detail-year-filter">
                <option value="">Все годы</option>
                {% for item in dashboard_payload.filters.years %}
                  <option value="{{ item.label }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-month-filter">Месяц</label>
              <select id="detail-month-filter">
                <option value="">Все месяцы</option>
                {% for item in dashboard_payload.filters.months %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-status-filter">Статус</label>
              <select id="detail-status-filter">
                <option value="">Все статусы</option>
                {% for item in dashboard_payload.filters.statuses %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-confidence-filter">Качество классификации</label>
              <select id="detail-confidence-filter">
                <option value="">Все уровни</option>
                <option value="high">high</option>
                <option value="medium">medium</option>
                <option value="low">low</option>
                <option value="unclassified">unclassified</option>
              </select>
            </div>
            <div>
              <label for="detail-l1-filter">Категория L1</label>
              <select id="detail-l1-filter">
                <option value="">Все L1</option>
                {% for item in dashboard_payload.filters.categories_l1 %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-l2-filter">Категория L2</label>
              <select id="detail-l2-filter">
                <option value="">Все L2</option>
                {% for item in dashboard_payload.filters.categories_l2 %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-l3-filter">Категория L3</label>
              <select id="detail-l3-filter">
                <option value="">Все L3</option>
                {% for item in dashboard_payload.filters.categories_l3 %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-vendor-filter">Поставщик</label>
              <select id="detail-vendor-filter">
                <option value="">Все поставщики</option>
                {% for item in dashboard_payload.filters.vendors %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label for="detail-organization-filter">Организация</label>
              <select id="detail-organization-filter">
                <option value="">Все организации</option>
                {% for item in dashboard_payload.filters.organizations %}
                  <option value="{{ item.id }}">{{ item.label }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
        </section>

        <div class="table-toolbar">
          <div>
            <label for="detail-search">Поиск</label>
            <input id="detail-search" type="search" placeholder="Контрагент, предмет расхода, организация, проект">
          </div>
          <div class="toolbar-actions">
            <button id="detail-export" class="secondary" type="button">CSV экспорт</button>
          </div>
          <div class="toolbar-actions">
            <button id="detail-reset" class="secondary" type="button">Сбросить</button>
          </div>
          <div id="detail-pagination-top" class="pagination-bar"></div>
        </div>

        <div id="active-filters" class="active-filters"></div>
        <div id="detail-table-summary" class="table-summary"></div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th data-sort-key="period_date">Дата</th>
                <th data-sort-key="vendor_label">Контрагент</th>
                <th data-sort-key="organization_label">Организация</th>
                <th data-sort-key="expense_subject">Предмет расхода</th>
                <th data-sort-key="project_name">Проект</th>
                <th data-sort-key="classification_confidence">Качество</th>
                <th data-sort-key="classification_reason_human">Почему отнесено в категорию</th>
                <th data-sort-key="status_group">Статус</th>
                <th data-sort-key="amount">Сумма, тыс. руб.</th>
              </tr>
            </thead>
            <tbody id="detail-table-body"></tbody>
          </table>
        </div>

        <div id="detail-pagination-bottom" class="pagination-bar pagination-bottom"></div>
      </article>
    </section>

    <div id="detail-modal" class="modal-backdrop hidden" aria-hidden="true">
      <div class="modal-window" role="dialog" aria-modal="true" aria-labelledby="detail-modal-title">
        <div class="modal-header">
          <div>
            <div class="group-kicker">Row Audit Trail</div>
            <h3 id="detail-modal-title" class="section-title">Детали строки</h3>
          </div>
          <button id="detail-modal-close" class="secondary" type="button">Закрыть</button>
        </div>
        <div class="modal-summary">
          <div id="detail-modal-summary" class="section-caption"></div>
        </div>
        <div class="modal-grid">
          <section class="modal-section">
            <h4 class="modal-section-title">Примененные правила</h4>
            <div id="detail-modal-transformations"></div>
          </section>
          <section class="modal-section">
            <h4 class="modal-section-title">Итоговые поля пайплайна</h4>
            <div id="detail-modal-pipeline" class="attr-grid"></div>
          </section>
        </div>
        <section class="modal-section">
          <h4 class="modal-section-title">Исходная строка из CSV</h4>
          <div id="detail-modal-raw" class="attr-grid attr-grid-raw"></div>
        </section>
      </div>
    </div>
  </main>
{% endblock %}
